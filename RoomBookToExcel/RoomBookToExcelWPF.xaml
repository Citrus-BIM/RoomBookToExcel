<Window x:Class="RoomBookToExcel.RoomBookToExcelWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:RoomBookToExcel"
        mc:Ignorable="d"

        Title="RoomBook в Excel"
        Height="280" Width="380"
        MinHeight="280" MinWidth="380"
        MaxHeight="280" MaxWidth="380"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/RoomBookToExcel;component/Resources/citrus.ico"
        WindowStartupLocation="CenterScreen"
        KeyDown="RoomBookToExcelWPF_KeyDown"

        FontFamily="{DynamicResource BaseFont}"
        FontSize="{DynamicResource FontSizeBase}"
        Foreground="{DynamicResource TextBrush}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        TextOptions.TextHintingMode="Fixed"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Language="ru-RU">

    <!-- Citrus theme -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- замени assembly/путь при необходимости -->
                <ResourceDictionary Source="/RoomBookToExcel;component/CitrusTheme/CitrusTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== CONTENT ===================== -->
        <StackPanel Grid.Row="0" Margin="0,10,0,0">

            <GroupBox x:Name="groupBox_ExportOption"
                      Header="Вариант экспорта:"
                      Margin="0,0,0,10">

                <Grid Margin="8,6,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <RadioButton x:Name="rbt_FinishingForEachRoom"
                                 Content="Отделка по каждому помещению"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"
                                 IsChecked="True"/>

                    <RadioButton x:Name="rbt_FloorFinishByCombinationInRoom"
                                 Grid.Row="1"
                                 Content="Отделка пола по сочетанию в помещении"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>

                    <RadioButton x:Name="rbt_WallFinishByCombinationInRoom"
                                 Grid.Row="2"
                                 Content="Отделка стен по сочетанию в помещении"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>

                    <RadioButton x:Name="rbt_CeilingFinishByCombinationInRoom"
                                 Grid.Row="3"
                                 Content="Потолки по сочетанию в помещении"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>

                    <RadioButton x:Name="rbt_WallFinishByCombinationWithCeiling"
                                 Grid.Row="4"
                                 Content="Отделка стен с учётом сочетания с потолками"
                                 VerticalContentAlignment="Center"
                                 Margin="0"/>
                </Grid>
            </GroupBox>

        </StackPanel>

        <!-- ===================== BUTTONS ===================== -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button x:Name="btn_Ok"
                        Content="Ок"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="0,0,5,0"
                        IsDefault="True"
                        Click="btn_Ok_Click"/>
                <Button x:Name="btn_Cancel"
                        Content="Отмена"
                        Width="100"
                        Height="32"
                        Padding="10,0,10,0"
                        Margin="5,0,0,0"
                        IsCancel="True"
                        Style="{StaticResource ButtonOutline}"
                        Click="btn_Cancel_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>